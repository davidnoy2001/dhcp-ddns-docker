;
; BIND reverse data file for local 192.168.0.XXX net
;
$TTL    604800
@       IN      SOA     filemon.tia.david. root.exemplo.com. (
                              2         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL
;
@       IN      NS      filemon.tia.david.
